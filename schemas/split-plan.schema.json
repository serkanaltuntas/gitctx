{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitctx.com/schemas/split-plan.schema.json",
  "title": "gitctx split plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "created_at", "windows"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date"
    },
    "description": {
      "type": "string"
    },
    "windows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "repo_url", "split", "start", "end", "reason"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "repo_url": {
            "type": "string",
            "minLength": 1
          },
          "split": {
            "type": "string",
            "enum": ["DEV", "REPORT", "HELD_OUT"]
          },
          "start": {
            "type": "string",
            "format": "date-time"
          },
          "end": {
            "type": "string",
            "format": "date-time"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "target_records": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
