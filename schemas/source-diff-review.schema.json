{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitctx.com/schemas/source-diff-review.schema.json",
  "title": "gitctx source diff review decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "source_diff_id",
    "source_repo_url",
    "source_commit",
    "parent_commit",
    "data_split",
    "changed_paths",
    "decision",
    "reasons",
    "notes",
    "reviewer",
    "review_timestamp",
    "review_protocol"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "source_diff_id": {
      "type": "string",
      "minLength": 1
    },
    "source_repo_url": {
      "type": "string",
      "minLength": 1
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "parent_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "data_split": {
      "type": "string",
      "enum": ["DEV", "REPORT", "HELD_OUT"]
    },
    "changed_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "decision": {
      "type": "string",
      "enum": ["needs_review", "accepted_for_teacher_labeling", "rejected"]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "review_timestamp": {
      "type": "string",
      "minLength": 1
    },
    "review_protocol": {
      "type": "string",
      "minLength": 1
    }
  }
}
