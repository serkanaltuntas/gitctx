{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitctx.com/schemas/training-example.schema.json",
  "title": "gitctx supervised fine-tuning example",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "artifact_name",
    "artifact_version",
    "source_diff_id",
    "teacher_input_id",
    "generated_label_id",
    "generated_label_review_id",
    "source_repo_url",
    "source_license",
    "source_commit",
    "parent_commit",
    "data_split",
    "changed_paths",
    "diff_stat",
    "historical_subject",
    "instruction",
    "diff",
    "diff_sha256",
    "messages",
    "target_header",
    "target_body",
    "target_footers",
    "target_message",
    "label_source",
    "review_decision",
    "review_issues",
    "review_notes",
    "reviewer",
    "review_timestamp",
    "teacher_model_id",
    "teacher_runtime",
    "teacher_runtime_model_id",
    "teacher_revision",
    "teacher_license",
    "teacher_size",
    "teacher_context_length",
    "prompt_version",
    "decoding_config",
    "generation_timestamp",
    "confidence",
    "verifier_score",
    "evidence_paths",
    "warnings",
    "parser_result"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "artifact_name": {"type": "string", "minLength": 1},
    "artifact_version": {"type": "string", "minLength": 1},
    "source_diff_id": {"type": "string", "minLength": 1},
    "teacher_input_id": {"type": "string", "minLength": 1},
    "generated_label_id": {"type": "string", "minLength": 1},
    "generated_label_review_id": {"type": "string", "minLength": 1},
    "source_repo_url": {"type": "string", "minLength": 1},
    "source_license": {"type": "string", "minLength": 1},
    "source_commit": {"type": "string", "pattern": "^[0-9a-f]{7,40}$"},
    "parent_commit": {"type": "string", "pattern": "^[0-9a-f]{7,40}$"},
    "data_split": {"type": "string", "enum": ["DEV", "REPORT"]},
    "changed_paths": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "diff_stat": {"type": "string"},
    "historical_subject": {"type": "string"},
    "instruction": {"type": "string", "minLength": 1},
    "diff": {"type": "string", "minLength": 1},
    "diff_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "messages": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "content"],
        "properties": {
          "role": {"type": "string", "enum": ["system", "user", "assistant"]},
          "content": {"type": "string"}
        }
      }
    },
    "target_header": {"type": "string", "minLength": 1},
    "target_body": {"type": "array", "items": {"type": "string"}},
    "target_footers": {"type": "array", "items": {"type": "string"}},
    "target_message": {"type": "string", "minLength": 1},
    "label_source": {
      "type": "string",
      "enum": [
        "teacher_generated_human_accepted",
        "teacher_generated_human_edited"
      ]
    },
    "review_decision": {"type": "string", "enum": ["accept", "edit"]},
    "review_issues": {"type": "array", "items": {"type": "string"}},
    "review_notes": {"type": "string"},
    "reviewer": {"type": "string", "minLength": 1},
    "review_timestamp": {"type": "string", "minLength": 1},
    "teacher_model_id": {"type": "string", "minLength": 1},
    "teacher_runtime": {"type": "string", "minLength": 1},
    "teacher_runtime_model_id": {"type": "string", "minLength": 1},
    "teacher_revision": {"type": "string", "pattern": "^[0-9a-f]{7,64}$"},
    "teacher_license": {"type": "string", "minLength": 1},
    "teacher_size": {"type": "string", "minLength": 1},
    "teacher_context_length": {"type": "string", "minLength": 1},
    "prompt_version": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$"},
    "decoding_config": {"type": "object"},
    "generation_timestamp": {"type": "string", "minLength": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "verifier_score": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_paths": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "parser_result": {"type": "object"}
  }
}
